{
  "scripts": {
    "build": "npm run css",
    "css-compile": "sass --load-path=node_modules --style=compressed --source-map css-src/main.scss:resources/cider-ci/public/css/main.css",
    "css-lint": "stylelint scss/",
    "css-prefix": "postcss resources/cider-ci/public/css/*.css --use autoprefixer --replace --map",
    "css-purge": "purgecss --keyframes --css resources/cider/public/css/main.css --content index.html \"node_modules/bootstrap/js/dist/{util,modal}.js\" --output assets/css/",
    "css": "npm-run-all css-compile css-prefix",
    "server": "serve --listen 3000",
    "start": "npm-run-all --parallel watch server",
    "watch": "nodemon -e html,scss -x \"npm run css\"",
    "test": "npm run css-lint && npm run css"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.4",
    "nodemon": "^2.0.15",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.12",
    "postcss-cli": "^9.1.0",
    "purgecss": "^4.1.3",
    "sass": "^1.83.0",
    "shadow-cljs": "^2.17.8"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.0.0",
    "@fortawesome/free-brands-svg-icons": "^7.0.0",
    "@fortawesome/free-regular-svg-icons": "^7.0.0",
    "@fortawesome/free-solid-svg-icons": "^7.0.0",
    "@fortawesome/react-fontawesome": "^3.0.0",
    "@js-joda/core": "3.2.0",
    "@js-joda/locale_en-us": "3.1.1",
    "@js-joda/timezone": "2.5.0",
    "bootstrap": "^5.3.3",
    "date-fns": "^2.29.2",
    "js-yaml": "^4.1.0",
    "react": "^19.2.3",
    "react-bootstrap": "^2.10.6",
    "react-dom": "^19.2.3"
  }
}